{
  "version": 2,
  "public": true,
  "buildCommand": "",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/api/pix", "destination": "/api/pix" },
    { "source": "/api/notify-order", "destination": "/api/notify-order" },
    { "source": "/api/create-payment", "destination": "/api/create-payment" },
    { "source": "/api/mp-webhook", "destination": "/api/mp-webhook" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ],
  "env": {
    "MP_ACCESS_TOKEN": "@mp_access_token"
  }
}
